{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rdp-signaling",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "Room"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["Room"]
    }
  ]
}
